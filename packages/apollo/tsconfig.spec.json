{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist/tests",
    "types": ["vitest/globals", "node"],
    "rootDir": ".",
    "resolveJsonModule": true,
    "paths": {
      "@nestjs/graphql": ["../graphql/lib"],
      "@nestjs/graphql/*": ["../graphql/lib/*"]
    }
  },
  "include": ["lib/**/*.ts", "tests/**/*.ts"],
  "references": [
    {
      "path": "../graphql/tsconfig.build.json"
    }
  ]
}
