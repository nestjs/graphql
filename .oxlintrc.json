{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "error"
  },
  "env": {
    "node": true
  },
  "ignorePatterns": ["packages/**/tests/**", "packages/**/dist/**"],
  "rules": {
    "typescript/no-explicit-any": "off",
    "typescript/no-require-imports": "off",
    "no-unused-vars": "off"
  }
}
